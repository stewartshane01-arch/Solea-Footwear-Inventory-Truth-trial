# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventory_db
# Alternative individual components if DATABASE_URL is not provided:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=inventory_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# eBay API Configuration
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id
EBAY_RUN_MODE=production  # or 'sandbox' for testing

# Gmail API Configuration
GMAIL_CREDENTIALS_PATH=./credentials.json  # Path to your Gmail credentials file
GMAIL_TOKEN_PATH=./token.json  # Path where Gmail token will be stored

# Secret Key for Flask
SECRET_KEY=your_secret_key_here

# Scheduler Configuration
AUTO_SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=60
AUTO_DELIST_ENABLED=true
AUTO_CROSSLIST_ENABLED=false

# API Configuration
API_PORT=9500
API_HOST=0.0.0.0

# eBay Sync Settings
AUTO_SYNC_EBAY_LISTINGS=true
AUTO_SYNC_SOLD_ITEMS=true

# pgAdmin Configuration
PGADMIN_PASSWORD=admin
